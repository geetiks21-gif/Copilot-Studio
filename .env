# .env — fill in your values, never commit this file

# Anthropic API key — get from console.anthropic.com
# Note: claude.ai subscription does NOT include API access.
# You need a separate API key from console.anthropic.com
# Free tier gives $5 credit to start.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI key — ONLY needed for embeddings (text-embedding-3-small)
# Embedding 1000 documents costs ~$0.02
# Get from platform.openai.com
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: LangSmith tracing (Step 5) — free at smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=equipment-agent-poc

GROQ_API_KEY=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